def url_ok(url: str) -> bool:
    try:
        request = urllib.request.Request(
            url,
            headers={"User-Agent": "Mozilla/5.0 BunnylandPlaywright/1.0"},
        )
        with urllib.request.urlopen(request, timeout=5) as response:
            return 200 <= response.status < 400
    except OSError:
        return False


def free_base_url() -> str:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        return f"http://127.0.0.1:{sock.getsockname()[1]}"


def ensure_server() -> tuple[subprocess.Popen[bytes] | None, str]:
    if BASE_URL:
        if url_ok(f"{BASE_URL}/index.html"):
            return None, BASE_URL
        if url_ok(f"{BASE_URL}/3d/index.html"):
            return None, f"{BASE_URL}/3d"
        base_url = BASE_URL
    else:
        base_url = free_base_url()
    web_root = Path(__file__).resolve().parents[1]
    dist_root = web_root / "dist"
    if not dist_root.exists():
        subprocess.run(["npm", "run", "build"], cwd=web_root, check=True)
    parsed = urlparse(base_url)
    port = str(parsed.port)
    serve_root = Path(tempfile.mkdtemp(prefix="bunnyland-3d-smoke-"))
    (serve_root / "3d").symlink_to(dist_root, target_is_directory=True)
    assets_root = dist_root / "assets"
    if assets_root.exists():
        (serve_root / "assets").symlink_to(assets_root, target_is_directory=True)
    proc = subprocess.Popen(
        ["python3", "-m", "http.server", port],
        cwd=serve_root,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    app_base_url = f"{base_url.rstrip('/')}/3d"
    deadline = time.monotonic() + 5
    while time.monotonic() < deadline:
        if url_ok(f"{app_base_url}/index.html"):
            return proc, app_base_url
        time.sleep(0.1)
    proc.terminate()
    raise RuntimeError(f"timed out waiting for {app_base_url}")


def route_api(page):
    page.route("**/mock/auth/session", lambda route: route.fulfill(status=200, json={
        "subject": "test-admin", "scopes": ["world:admin"],
        "expires_at": 4102444800, "rotate_after": None, "rotation_eligible": False,
    }))
    prop_asset = (
        Path(__file__).resolve().parents[1]
        / "dist"
        / "assets"
        / "3d"
        / "prop-generic.gltf"
    )
    prop_data = json.loads(prop_asset.read_text())
    prop_data["scenes"][0]["nodes"].append(1)
    prop_data["nodes"].append({
        "name": "HiddenAnchor",
        "mesh": 1,
        "translation": [0.7, 0.3, 0],
        "scale": [0.2, 0.2, 0.2],
    })
    prop_data["meshes"].append({
        "name": "HiddenAnchorMesh",
        "primitives": [{
            "attributes": {"POSITION": 0, "NORMAL": 1},
            "indices": 2,
            "material": 1,
        }],
    })
    prop_data["materials"].append({
        "name": "HiddenAnchorMaterial",
        "pbrMetallicRoughness": {
            "baseColorFactor": [0.8, 0.84, 0.96, 0],
            "metallicFactor": 0,
            "roughnessFactor": 0.82,
        },
        "alphaMode": "BLEND",
    })
    page.route(
        "**/assets/3d/prop-hidden.glb",
        lambda route: route.fulfill(
            body=json.dumps(prop_data), content_type="model/gltf+json"
        ),
    )
    page.route(
        "**/assets/3d/prop-generic.glb",
        lambda route: route.fulfill(path=prop_asset, content_type="model/gltf-binary"),
    )
    page.route(
        "**/assets/3d/prop-delayed.glb",
        lambda route: (time.sleep(0.35), route.fulfill(path=prop_asset, content_type="model/gltf-binary")),
    )
    page.route("**/mock/play/extensions/bunnyland.3d/3d/v2/capabilities", lambda route: route.fulfill(status=200, json={
        "ok": True,
        "plugin_id": "bunnyland.3d",
        "plugin_version": "0.3.0",
        "scene_schema_version": 4,
        "asset_schema_version": 2,
    }))
    page.route("**/mock/play/extensions/bunnyland.3d/3d/v2/assets/manifest", lambda route: route.fulfill(status=200, json={
        "schema_version": 2,
        "assets": {
            key: {
                "url": (
                    "/assets/3d/prop-hidden.glb"
                    if key == "bunnyland.test/prop"
                    else "/assets/3d/prop-delayed.glb"
                    if key == "bunnyland.test/delayed"
                    else "/assets/3d/prop-generic.glb"
                ),
                "digest": f"fake-{key.rsplit('/', 1)[-1]}",
                "transform": {"scale": 1, "rotation": [0, 0, 0], "translation": [0, 0, 0]},
                "clips": {},
                "variants": [],
                "default_color": "",
                "instanced": True,
                "license": "AGPL-3.0-or-later",
                "attribution": "Bunnyland contributors",
                "nodes": ["GenericProp", "HiddenAnchor"],
                "semantic_roles": {"state-indicator": ["GenericProp"]},
            }
            for key in (
                "bunnyland.anglersim/fishing-pond",
                "bunnyland.wildsim/berry-bush",
                "bunnyland.wildsim/deciduous-tree",
                "bunnyland.test/prop",
                "bunnyland.test/delayed",
                "bunnyland.test/attachment",
            )
        },
    }))

    def scene_control_route(route):
        SCENE_STATE.update(route.request.post_data_json or {})
        route.fulfill(status=200, json={"ok": True, "state": SCENE_STATE})

    page.route("**/mock/test-scene", scene_control_route)

    def claim_control_route(route):
        if route.request.method == "POST":
            CLAIM_STATE.update(route.request.post_data_json or {})
        route.fulfill(status=200, json={"ok": True, **CLAIM_STATE})

    page.route("**/mock/test-claim", claim_control_route)

    def scene_route(route):
        CLAIM_STATE["room_requests"] += 1
        room_id = unquote(route.request.url.rsplit("/3d/v2/room/", 1)[1])
        route.fulfill(status=200, json=player_3d_scene(room_id))

    page.route("**/mock/play/extensions/bunnyland.3d/3d/v2/room/**", scene_route)
    page.route("**/mock/admin/extensions/bunnyland.3d/3d/**", lambda route: route.fulfill(status=200, json={
        "ok": True,
        "status": "preview" if route.request.method == "GET" else "applied",
        "recipe": "meadow",
        "instances": 92,
        "has_roof": bool((route.request.post_data_json or {}).get("has_roof")) if route.request.post_data else False,
    }))
    page.route("**/mock/admin/world", lambda route: route.fulfill(status=200, json=OVERVIEW))
    page.route("**/mock/admin/world/snapshot", lambda route: route.fulfill(status=200, json={"entities": []}))
    def characters_route(route):
        CLAIM_STATE["character_requests"] += 1
        route.fulfill(status=200, json={
            "ok": True,
            "world_epoch": 21,
            "characters": [{"id": "character:ash", "name": "Ash", "kind": "character", "suspended": True}],
        })

    page.route("**/mock/play/characters", characters_route)
    def claim_route(route):
        CLAIM_STATE["methods"].append(route.request.method)
        if route.request.method == "DELETE":
            claim_release_route(route)
            return
        payload = route.request.post_data_json or {}
        if route.request.method == "PATCH" and payload.get("kind") == "fallback":
            controller_fallback_route(route)
            return
        if route.request.method == "PATCH" and payload.get("kind") == "control":
            controller_release_route(route)
            return
        if route.request.method == "PUT" and CLAIM_STATE["expired"]:
            route.fulfill(status=404, json={"detail": "claim does not exist"})
            return
        if route.request.method == "POST":
            CLAIM_STATE["expired"] = False
        route.fulfill(status=200, headers={"X-Bunnyland-Claim-Secret": "secret-1"}, json={
            "id": "claim-1",
            "character_id": "character:ash",
            "controller_id": "controller:web",
            "generation": 3,
            "fallback_controller": "suspend",
            "timeout_seconds": 1800,
        })

    page.route("**/mock/play/claims/**", claim_route)
    page.route("**/mock/play/claims", claim_route)

    def character_route(route):
        path = route.request.url.split("/mock/play/claims/", 1)[1].split("?", 1)[0]
        if path.endswith("/jobs"):
            RECENT_EVENTS.append({
                "event_type": "ImageGenerationCompletedEvent",
                "event": {
                    "event_id": f"event:image:{len(RECENT_EVENTS)}",
                    "entity_id": "character:ash",
                    "purpose": "event",
                    "url": NEW_SCENE_IMAGE_URL,
                    "world_epoch": 22 + len(RECENT_EVENTS),
                    "visibility": "private",
                    "actor_id": "character:ash",
                },
            })
            route.fulfill(status=200, json={"ok": True, "status": "queued"})
            return
        if path.endswith("/events"):
            CLAIM_STATE["event_requests"] += 1
            if route.request.headers.get("x-bunnyland-claim-secret") != "secret-1":
                route.fulfill(status=403, json={"detail": "missing claim secret"})
                return
            route.fulfill(status=200, json={"ok": True, "events": RECENT_EVENTS})
            return
        if "/commands/" in path and route.request.method == "DELETE":
            command_id = unquote(path.rsplit("/", 1)[1])
            PLAYER_QUEUE[:] = [command for command in PLAYER_QUEUE if command.get("command_id") != command_id]
            route.fulfill(status=200, json={"ok": True, "cancelled": True, "command_id": command_id})
            return
        if path.endswith("/commands") and route.request.method == "POST":
            player_command_route(route)
            return
        CLAIM_STATE["projection_requests"] += 1
        if CLAIM_STATE["expired"]:
            route.fulfill(status=404, json={"detail": "claim does not exist"})
            return
        projection = player_projection()
        projection.update({"next_tick_at_unix": time.time() + 8, "commands": PLAYER_QUEUE})
        route.fulfill(status=200, json=projection)

    page.route("**/mock/play/claims/**/projection", character_route)
    page.route("**/mock/play/claims/**/events", character_route)
    page.route("**/mock/play/claims/**/jobs", character_route)
    page.route("**/mock/play/claims/**/commands", character_route)
    page.route("**/mock/play/claims/**/commands/**", character_route)


def player_command_route(route):
    global PLAYER_ROOM_ID
    payload = route.request.post_data_json
    COMMAND_PAYLOADS.append(payload)
    if payload.get("command_type") == "move":
        PLAYER_ROOM_ID = payload.get("payload", {}).get("exit_id", PLAYER_ROOM_ID)
    route.fulfill(status=200, json={"ok": True, "queued": True, "command_id": "cmd-new"})


def controller_fallback_route(route):
    global FALLBACK_SAVED
    FALLBACK_SAVED = True
    route.fulfill(status=200, json={"ok": True, **route.request.post_data_json})


def controller_release_route(route):
    global CONTROLLER_RELEASED
    CONTROLLER_RELEASED = True
    route.fulfill(status=200, json={
        "ok": True,
        "character_id": "character:ash",
        "controller_id": "controller:web",
        "controller_generation": 4,
        "claim_id": "claim-1",
        "claim_secret": "secret-1",
    })


def claim_release_route(route):
    global CLAIM_RELEASED
    CLAIM_RELEASED = True
    route.fulfill(status=200, json={"ok": True, "released": True})


def png_has_detail(path: Path) -> bool:
    data = path.read_bytes()
    if not data.startswith(b"\x89PNG\r\n\x1a\n"):
        return False
    width = height = color_type = None
    idat = bytearray()
    index = 8
    while index < len(data):
        length = struct.unpack(">I", data[index : index + 4])[0]
        chunk_type = data[index + 4 : index + 8]
        chunk_data = data[index + 8 : index + 8 + length]
        index += length + 12
        if chunk_type == b"IHDR":
            width, height, bit_depth, color_type, _, _, _ = struct.unpack(">IIBBBBB", chunk_data)
            if bit_depth != 8 or color_type not in (2, 6):
                return False
        elif chunk_type == b"IDAT":
            idat.extend(chunk_data)
        elif chunk_type == b"IEND":
            break
    if width is None or height is None or color_type is None:
        return False
    channels = 4 if color_type == 6 else 3
    stride = width * channels
    raw = zlib.decompress(bytes(idat))
    previous = bytearray(stride)
    first_pixel: tuple[int, int, int] | None = None
    varied = 0
    offset = 0
    for _ in range(height):
        filter_type = raw[offset]
        offset += 1
        row = bytearray(raw[offset : offset + stride])
        offset += stride
        for i, value in enumerate(row):
            left = row[i - channels] if i >= channels else 0
            up = previous[i]
            upper_left = previous[i - channels] if i >= channels else 0
            if filter_type == 1:
                row[i] = (value + left) & 0xFF
            elif filter_type == 2:
                row[i] = (value + up) & 0xFF
            elif filter_type == 3:
                row[i] = (value + ((left + up) // 2)) & 0xFF
            elif filter_type == 4:
                predictor = left + up - upper_left
                pa = abs(predictor - left)
                pb = abs(predictor - up)
                pc = abs(predictor - upper_left)
                row[i] = (value + (left if pa <= pb and pa <= pc else up if pb <= pc else upper_left)) & 0xFF
            elif filter_type != 0:
                return False
        for i in range(0, stride, channels * 40):
            pixel = (row[i], row[i + 1], row[i + 2])
            if first_pixel is None:
                first_pixel = pixel
            elif sum(abs(pixel[channel] - first_pixel[channel]) for channel in range(3)) > 28:
                varied += 1
                if varied >= 16:
                    return True
        previous = row
    return False


def download_capture_from_button(page, path: Path) -> None:
    with page.expect_download() as download_info:
        page.locator("#btn-capture").click()
    download = download_info.value
    download.save_as(path)


def download_lightbox_photo(page, path: Path) -> None:
    with page.expect_download() as download_info:
        page.locator("#btn-lightbox-download").click()
    download = download_info.value
    download.save_as(path)


def patch_player_scene(page, patch):
    page.evaluate(
        """async patch => {
          await fetch('./mock/test-scene', {
            method: 'POST',
            headers: {'content-type': 'application/json'},
            body: JSON.stringify(patch),
          });
          await window.__world3dPlayer.refresh();
          await new Promise(resolve => setTimeout(resolve, 20));
          await window.__world3dPlayer.refresh();
        }""",
        patch,
    )


def assert_responsive_toolbar(page, name: str, *, character: bool = False) -> None:
    original_viewport = page.viewport_size
    page.set_viewport_size({"width": 390, "height": 760})
    layout = page.evaluate(
        """async ({character}) => {
          const toolbar = document.querySelector('#toolbar');
          const status = document.querySelector('#status');
          const originalStatus = status?.textContent || '';
          if (status) {
            status.textContent = 'Connection failed: ' +
              'upstream-gateway-with-an-unusually-long-hostname.example.invalid/'.repeat(5);
          }
          await new Promise(resolve => requestAnimationFrame(() => requestAnimationFrame(resolve)));
          const rows = [...toolbar.querySelectorAll(':scope > .toolbar-row')].map((row, index) => ({
            index,
            brand: Boolean(row.querySelector('.toolbar-brand')),
            menu: Boolean(row.querySelector('#btn-client-menu')),
            api: Boolean(row.querySelector('#api-url')),
            character: Boolean(row.querySelector('#character-select')),
            borderTopWidth: getComputedStyle(row).borderTopWidth,
            clientWidth: row.clientWidth,
            scrollWidth: row.scrollWidth,
          }));
          const result = {
            rows,
            clientWidth: toolbar.clientWidth,
            scrollWidth: toolbar.scrollWidth,
            documentScrollWidth: document.documentElement.scrollWidth,
            viewportWidth: innerWidth,
            expectsCharacter: character,
          };
          if (status) status.textContent = originalStatus;
          return result;
        }""",
        {"character": character},
    )
    if layout["scrollWidth"] > layout["clientWidth"] + 1 or layout["documentScrollWidth"] > layout["viewportWidth"] + 1:
        raise AssertionError(f"{name} toolbar overflows horizontally: {layout!r}")
    rows = layout["rows"]
    if not rows or not rows[0]["brand"] or not rows[0]["menu"]:
        raise AssertionError(f"{name} title and menu are not together on the first row: {layout!r}")
    if not any(row["api"] and row["index"] == 1 for row in rows):
        raise AssertionError(f"{name} server controls are not on the second row: {layout!r}")
    if character and not any(row["character"] and row["index"] == 2 for row in rows):
        raise AssertionError(f"{name} character selection is not on the third row: {layout!r}")
    for row in rows:
        if row["scrollWidth"] > row["clientWidth"] + 1:
            raise AssertionError(f"{name} toolbar row overflows horizontally: {layout!r}")
        if row["index"] and row["borderTopWidth"] == "0px":
            raise AssertionError(f"{name} toolbar row lacks a separator: {layout!r}")
    page.locator("#btn-client-menu").click()
    menu_link = page.locator("#client-menu-dialog .client-menu-item").filter(has_text="Toon Client").first
    menu_link.wait_for(state="visible")
    menu_href = menu_link.get_attribute("href") or ""
    if menu_href.split("?", 1)[0] != "/toon-client.html":
        raise AssertionError(f"{name} menu link does not resolve from the site root: {menu_href!r}")
    page.keyboard.press("Escape")
    if original_viewport:
        page.set_viewport_size(original_viewport)


def main() -> None:
    ARTIFACT_DIR.mkdir(parents=True, exist_ok=True)
    proc, base_url = ensure_server()
    try:
        with sync_playwright() as playwright:
            browser = playwright.chromium.launch(headless=True)
            page = browser.new_page(viewport=VIEWPORT)
            requested_urls = []
            page.on("request", lambda request: requested_urls.append(request.url))
            page.add_init_script("""
              window.__playerProgressEvents = [];
              window.addEventListener('bunnyland:3d-player-progress', event => {
                window.__playerProgressEvents.push(event.detail);
              });
            """)
            route_api(page)
            page.goto(f"{base_url}/index.html", wait_until="networkidle")
            expect(page.locator("#welcome-title")).to_contain_text("Play and inspect")
            expect(page.locator('a[href="player.html"]').first).to_contain_text("Open 3D Player")
            expect(page.locator('a[href="admin.html"]').first).to_contain_text("Open 3D Admin")
            page.locator("#theme-select").select_option("anime-light")
            welcome_theme = page.evaluate(
                """() => ({
                  current: document.documentElement.dataset.theme,
                  anime: document.documentElement.classList.contains('bl-theme-anime-light')
                })"""
            )
            if welcome_theme != {"current": "anime-light", "anime": True}:
                raise AssertionError(f"welcome page did not use shared theme setup: {welcome_theme!r}")
            if any("three.module-" in url or "gltf-assets-" in url for url in requested_urls):
                raise AssertionError("welcome page eagerly loaded the 3D renderer or model tools")
            page.goto(f"{base_url}/admin.html?server={base_url}/mock", wait_until="networkidle")
            page.wait_for_function("window.__world3d && window.__world3d.ready")
            if not any("three.module-" in url for url in requested_urls):
                raise AssertionError("admin page did not load the deferred Three.js chunk")
            expect(page.locator("#status")).to_contain_text("loaded 3 rooms")
            assert_responsive_toolbar(page, "3D admin")
            page.locator("#btn-preview-decoration").click()
            expect(page.locator("#decoration-result")).to_contain_text('"instances":92')
            page.locator("#room-has-roof").check()
            expect(page.locator("#status")).to_contain_text("roof enabled")
            page.locator("#theme-select").select_option("anime-light")
            theme = page.evaluate(
                """() => ({
                  current: document.documentElement.dataset.theme,
                  anime: document.documentElement.classList.contains('bl-theme-anime-light')
                })"""
            )
            if theme != {"current": "anime-light", "anime": True}:
                raise AssertionError(f"theme selector did not use shared theme setup: {theme!r}")
            scene_theme = page.evaluate("window.__world3d.themeState()")
            if scene_theme["theme"] != "anime-light" or scene_theme["background"].lower() != "#efd0e2":
                raise AssertionError(f"3D scene did not use selected theme colors: {scene_theme!r}")
            page.locator("#viewer canvas").hover()
            radius_before = page.evaluate("window.__world3d.cameraState().radius")
            page.mouse.wheel(0, -600)
            radius_after = page.evaluate("window.__world3d.cameraState().radius")
            if not radius_after < radius_before:
                raise AssertionError(f"auto camera wheel did not zoom in: {radius_before!r} -> {radius_after!r}")
            if page.locator('[data-entity-id="item:clover"]').count() == 0:
                raise AssertionError(
                    "admin room entities did not load: "
                    f"status={page.locator('#status').text_content()!r} "
                    f"entities={page.locator('#selected-entities').text_content()!r}"
                )
            page.locator('[data-entity-id="item:clover"]').click()
            if "active" not in (page.locator('[data-entity-id="item:clover"]').get_attribute("class") or ""):
                raise AssertionError("selected entity row did not become active")
            motion = page.evaluate(
                """async () => {
                  const before = window.__world3d.cameraState();
                  const selectPromise = window.__world3d.selectRoom('room:pond');
                  const during = window.__world3d.cameraState();
                  await selectPromise;
                  return { before, during };
                }"""
            )
            if not motion["during"]["moving"]:
                raise AssertionError(f"room selection did not animate camera: {motion!r}")
            page.wait_for_function("!window.__world3d.cameraState().moving")
            after = page.evaluate("window.__world3d.cameraState()")
            if after["moving"]:
                raise AssertionError("camera transition did not settle")
            if after["target"] == motion["before"]["target"]:
                raise AssertionError(f"camera target did not change after room switch: {motion!r} -> {after!r}")
            page.wait_for_timeout(250)
            canvas_3d = ARTIFACT_DIR / "world-3d-canvas-3d.png"
            download_capture_from_button(page, canvas_3d)
            if not png_has_detail(canvas_3d):
                raise AssertionError("3D canvas rendered blank pixels")
            page.screenshot(
                path=ARTIFACT_DIR / "world-3d-3d.png",
                full_page=FULL_PAGE_SCREENSHOTS,
            )
            page.locator("#btn-mode").click()
            page.wait_for_timeout(150)
            static_frames = page.evaluate("window.__world3d.renderState().frames")
            page.wait_for_timeout(180)
            settled_frames = page.evaluate("window.__world3d.renderState().frames")
            if settled_frames != static_frames:
                raise AssertionError(
                    f"static 2D admin view kept rendering: {static_frames} -> {settled_frames}"
                )
            canvas_2d = ARTIFACT_DIR / "world-3d-canvas-2d.png"
            download_capture_from_button(page, canvas_2d)
            if not png_has_detail(canvas_2d):
                raise AssertionError("2D canvas rendered blank pixels")
            page.screenshot(
                path=ARTIFACT_DIR / "world-3d-2d.png",
                full_page=FULL_PAGE_SCREENSHOTS,
            )
            page.locator('[data-room-id="room:pond"]').click()
            expect(page.locator("#selected-entities")).to_contain_text("Bright Pebble")

            page.goto(f"{base_url}/player.html?server={base_url}/mock", wait_until="networkidle")
            page.wait_for_function("window.__world3dPlayer && window.__world3dPlayer.ready")
            expect(page.locator("#status")).to_contain_text("loaded 1 characters")
            assert_responsive_toolbar(page, "3D player", character=True)
            expect(page.locator("#empty-state-title")).to_contain_text("Pick a character to start")
            idle_render = page.evaluate("window.__world3dPlayer.renderState()")
            if idle_render["frames"] != 0 or idle_render["scheduled"]:
                raise AssertionError(f"player rendered before a room was selected: {idle_render!r}")
            if any("gltf-assets-" in url for url in requested_urls):
                raise AssertionError("player loaded model tools before a character selected a room")
            empty_state = page.evaluate(
                """() => {
                  const main = document.querySelector('#main').getBoundingClientRect();
                  const state = document.querySelector('#empty-state').getBoundingClientRect();
                  return {
                    dx: Math.abs((main.left + main.width / 2) - (state.left + state.width / 2)),
                    dy: Math.abs((main.top + main.height / 2) - (state.top + state.height / 2)),
                    textAlign: getComputedStyle(document.querySelector('#empty-state')).textAlign,
                  };
                }"""
            )
            if empty_state["dx"] > 2 or empty_state["dy"] > 2 or empty_state["textAlign"] != "center":
                raise AssertionError(f"player empty state was not centered: {empty_state!r}")
            page.locator("#character-select").select_option("character:ash")
            expect(page.locator("#room-title")).to_contain_text("Sunlit Meadow")
            initial_countdown = page.locator("#queue-title").text_content()
            page.wait_for_function(
                "initial => document.querySelector('#queue-title')?.textContent !== initial",
                arg=initial_countdown,
                timeout=2000,
            )
            page.wait_for_function("!window.__world3dPlayer.cameraState().moving")
            page.wait_for_function(
                "window.__world3dPlayer.entityVisualState('item:crate')?.attachmentCount === 1"
            )
            if not any("gltf-assets-" in url for url in requested_urls):
                raise AssertionError("player did not defer model tools until room assets were needed")
            progress_events = page.evaluate("window.__playerProgressEvents")
            if not any(event["active"] and event["total"] > 0 for event in progress_events):
                raise AssertionError(f"scene asset loading progress was not reported: {progress_events!r}")
            if not progress_events or progress_events[-1]["active"]:
                raise AssertionError(f"scene asset loading did not settle: {progress_events!r}")
            expect(page.locator("#viewer .canvas-loading")).to_have_count(0)
            player_frames = page.evaluate("window.__world3dPlayer.renderState().frames")
            page.wait_for_timeout(120)
            if page.evaluate("window.__world3dPlayer.renderState().frames") <= player_frames:
                raise AssertionError("active player room did not continue rendering")
            entity_visual = page.evaluate(
                "window.__world3dPlayer.entityVisualState('item:crate')"
            )
            if not entity_visual["loaded"] or abs(entity_visual["opacity"] - 0.42) > 0.001:
                raise AssertionError(f"entity GLB patches were not applied: {entity_visual!r}")
            if entity_visual["helperOpacity"] != 0:
                raise AssertionError(f"wildcard patch exposed hidden model geometry: {entity_visual!r}")
            if entity_visual["colorHex"] == "112233":
                raise AssertionError(f"legacy Render3D color replaced the GLB material: {entity_visual!r}")
            if not entity_visual["effectGroup"] or entity_visual["effectParticles"] != 12 or entity_visual["effectLightning"] != 3:
                raise AssertionError(f"entity effects were not preserved across GLB replacement: {entity_visual!r}")
            page.wait_for_function("window.__world3dPlayer.visualState().modelPropInstances === 7")
            visual_state = page.evaluate("window.__world3dPlayer.visualState()")
            if visual_state != {"propInstances": 7, "modelPropInstances": 7, "particles": 48, "localLights": 1, "skybox": True, "skyboxPreset": "vendor.weather/day", "particleSystems": ["vendor.weather/embers", "vendor.weather/snow"]}:
                raise AssertionError(f"provider model did not replace the procedural decoration: {visual_state!r}")

            page.evaluate("window.__world3dPlayer.selectTarget('item:crate')")
            before_reconcile = page.evaluate("window.__world3dPlayer.reconciliationState()")
            progress_count = page.evaluate("window.__playerProgressEvents.length")
            page.evaluate("window.__world3dPlayer.refresh()")
            after_reconcile = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if after_reconcile["environment"] != before_reconcile["environment"]:
                raise AssertionError("identical refresh replaced the environment")
            if after_reconcile["decorations"] != before_reconcile["decorations"] or after_reconcile["exits"] != before_reconcile["exits"]:
                raise AssertionError("identical refresh replaced room decorations or exits")
            for entity_id, before_entity in before_reconcile["entities"].items():
                after_entity = after_reconcile["entities"][entity_id]
                for field in ("root", "model", "selection", "legacyEffects", "registeredEffects"):
                    if after_entity[field] != before_entity[field]:
                        raise AssertionError(f"identical refresh replaced {entity_id} {field}")
            if after_reconcile["entities"]["character:ash"]["mixerTime"] < before_reconcile["entities"]["character:ash"]["mixerTime"]:
                raise AssertionError("identical refresh reset player animation time")
            if after_reconcile["resources"] != before_reconcile["resources"]:
                raise AssertionError(f"identical refresh changed resource counts: {before_reconcile['resources']!r} -> {after_reconcile['resources']!r}")
            refresh_progress = page.evaluate("start => window.__playerProgressEvents.slice(start)", progress_count)
            if any(event["active"] for event in refresh_progress):
                raise AssertionError(f"identical refresh flashed asset progress: {refresh_progress!r}")

            original_effects = after_reconcile["entities"]["item:crate"]["registeredEffects"]
            patch_player_scene(page, {"effect_remaining": 4})
            countdown_state = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if countdown_state["entities"]["item:crate"]["registeredEffects"] != original_effects:
                raise AssertionError("effect countdown refresh rebuilt particle or lightning buffers")

            crate_root = countdown_state["entities"]["item:crate"]["root"]
            crate_model = countdown_state["entities"]["item:crate"]["model"]
            patch_player_scene(page, {"crate_x": 11.25})
            moved_state = page.evaluate("window.__world3dPlayer.reconciliationState()")
            moved_crate = moved_state["entities"]["item:crate"]
            if moved_crate["root"] != crate_root or moved_crate["model"] != crate_model or abs(moved_crate["position"][0] - 11.25) > 0.001:
                raise AssertionError(f"remote transform did not patch the existing visual: {moved_crate!r}")

            patch_player_scene(page, {"extra_effect": True})
            added_effect_state = page.evaluate("window.__world3dPlayer.reconciliationState()")
            added_effects = added_effect_state["entities"]["item:crate"]["registeredEffects"]
            if len(added_effects) != 2 or not set(original_effects.items()).issubset(set(added_effects.items())):
                raise AssertionError(f"adding one effect replaced existing effects: {original_effects!r} -> {added_effects!r}")
            patch_player_scene(page, {"extra_effect": False})
            removed_effects = page.evaluate("window.__world3dPlayer.reconciliationState().entities['item:crate'].registeredEffects")
            if removed_effects != original_effects:
                raise AssertionError(f"removing one effect replaced the surviving effect: {removed_effects!r}")

            before_structure = page.evaluate("window.__world3dPlayer.reconciliationState()")
            patch_player_scene(page, {"model_opacity": 0.31})
            page.wait_for_function("Math.abs(window.__world3dPlayer.entityVisualState('item:crate').opacity - 0.31) < 0.001")
            after_structure = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if after_structure["entities"]["item:crate"]["root"] != before_structure["entities"]["item:crate"]["root"] or after_structure["entities"]["item:crate"]["model"] == before_structure["entities"]["item:crate"]["model"]:
                raise AssertionError("node patch change did not localize replacement to the entity model")
            if after_structure["entities"]["character:ash"]["model"] != before_structure["entities"]["character:ash"]["model"]:
                raise AssertionError("crate node patch replaced the player model")

            delayed_root = after_structure["entities"]["item:crate"]["root"]
            delayed_old_model = after_structure["entities"]["item:crate"]["model"]
            page.evaluate(
                """async () => {
                  await fetch('./mock/test-scene', {
                    method: 'POST',
                    headers: {'content-type': 'application/json'},
                    body: JSON.stringify({model_asset: 'bunnyland.test/delayed'}),
                  });
                  await window.__world3dPlayer.refresh();
                  setTimeout(() => { void window.__world3dPlayer.refresh(); }, 25);
                }"""
            )
            page.wait_for_function(
                "oldModel => window.__world3dPlayer.reconciliationState().entities['item:crate'].model !== oldModel",
                arg=delayed_old_model,
            )
            delayed_state = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if delayed_state["entities"]["item:crate"]["root"] != delayed_root:
                raise AssertionError("unchanged projection replaced an entity while its model load was pending")
            patch_player_scene(page, {"model_asset": "bunnyland.test/prop"})
            page.wait_for_function("window.__world3dPlayer.entityVisualState('item:crate')?.attachmentCount === 1")

            before_decoration = page.evaluate("window.__world3dPlayer.reconciliationState()")
            patch_player_scene(page, {"decoration_color": "#71a84f"})
            page.wait_for_function("window.__world3dPlayer.visualState().modelPropInstances === 7")
            after_decoration = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if after_decoration["decorations"]["decoration:flora"] == before_decoration["decorations"]["decoration:flora"]:
                raise AssertionError("changed decoration was not rebuilt")
            for decoration_id in ("decoration:light", "decoration:particles"):
                if after_decoration["decorations"][decoration_id] != before_decoration["decorations"][decoration_id]:
                    raise AssertionError(f"flora change replaced unrelated {decoration_id}")

            patch_player_scene(page, {"sky_color": "#88bde4"})
            after_environment = page.evaluate("window.__world3dPlayer.reconciliationState()")
            if after_environment["environment"] == after_decoration["environment"]:
                raise AssertionError("environment definition change was not rendered")
            if after_environment["decorations"] != after_decoration["decorations"]:
                raise AssertionError("environment change replaced decorations")
            if {key: value["root"] for key, value in after_environment["entities"].items()} != {key: value["root"] for key, value in after_decoration["entities"].items()}:
                raise AssertionError("environment change replaced entities")

            departed_root = after_environment["entities"]["item:crate"]["root"]
            patch_player_scene(page, {"hidden_entities": ["item:crate"]})
            if page.evaluate("'item:crate' in window.__world3dPlayer.reconciliationState().entities"):
                raise AssertionError("removed entity remained in the scene")
            patch_player_scene(page, {"hidden_entities": []})
            page.wait_for_function("window.__world3dPlayer.entityVisualState('item:crate')?.attachmentCount === 1")
            returned_root = page.evaluate("window.__world3dPlayer.reconciliationState().entities['item:crate'].root")
            if returned_root == departed_root:
                raise AssertionError("entity returning after an absence reused a disposed visual")

            page.wait_for_timeout(600)
            camera_clearance = page.evaluate("window.__world3dPlayer.cameraState()")
            if abs(camera_clearance["actualRadius"] - camera_clearance["radius"]) > 0.25:
                raise AssertionError(f"decoration changed camera distance: {camera_clearance!r}")
            layout = page.evaluate(
                """() => {
                  const side = document.querySelector('#side');
                  const panel = side.querySelector('.panel');
                  const actions = document.querySelector('#actions');
                  const queuePanel = document.querySelector('.queue-panel');
                  const actionsPanel = document.querySelector('.actions-panel');
                  return {
                    sideOverflowX: getComputedStyle(side).overflowX,
                    sideScrollWidth: side.scrollWidth,
                    sideClientWidth: side.clientWidth,
                    panelPaddingLeft: parseFloat(getComputedStyle(panel).paddingLeft),
                    actionsOverflowY: getComputedStyle(actions).overflowY,
                    actionsScrollHeight: actions.scrollHeight,
                    actionsClientHeight: actions.clientHeight,
                    queueTop: queuePanel.getBoundingClientRect().top,
                    actionsTop: actionsPanel.getBoundingClientRect().top,
                  };
                }"""
            )
            if layout["sideOverflowX"] != "hidden" or layout["sideScrollWidth"] > layout["sideClientWidth"] + 1:
                raise AssertionError(f"player sidebar overflowed horizontally: {layout!r}")
            if layout["panelPaddingLeft"] < 10:
                raise AssertionError(f"player sidebar panels lacked padding: {layout!r}")
            if layout["actionsOverflowY"] != "auto" or layout["actionsScrollHeight"] <= layout["actionsClientHeight"]:
                raise AssertionError(f"player actions did not have an internal scrollbar: {layout!r}")
            if layout["queueTop"] >= layout["actionsTop"]:
                raise AssertionError(f"pending actions were not placed before the action list: {layout!r}")
            exits = page.evaluate("window.__world3dPlayer.exitStates()")
            east_exit = next(exit_state for exit_state in exits if exit_state["side"] == "east")
            north_exit = next(exit_state for exit_state in exits if exit_state["side"] == "north")
            if abs(abs(east_exit["rotationY"]) - 1.5708) > 0.01 or abs(east_exit["x"] - 15.75) > 0.01:
                raise AssertionError(f"east door did not align with its wall: {east_exit!r}")
            if abs(north_exit["rotationY"]) > 0.01 or abs(north_exit["z"] - 0.25) > 0.01:
                raise AssertionError(f"north door did not align with its wall: {north_exit!r}")
            page.locator("#btn-hud").click()
            stacked_point = page.evaluate("window.__world3dPlayer.entityScreenPoint('item:clover')")
            page.mouse.click(stacked_point["x"], stacked_point["y"])
            expect(page.locator("#target-label")).to_contain_text("Silver Clover")
            page.mouse.click(stacked_point["x"], stacked_point["y"])
            expect(page.locator("#target-label")).to_contain_text("Ash")
            distant_prop_point = page.evaluate("window.__world3dPlayer.entityScreenPoint('item:crate')")
            page.mouse.click(distant_prop_point["x"], distant_prop_point["y"])
            page.locator("#btn-hud").click()
            expect(page.locator("#target-label")).to_contain_text("Green Crate")
            page.locator("#btn-hud").click()
            page.locator("#viewer canvas").click(position={"x": 20, "y": 20})
            page.locator("#btn-hud").click()
            expect(page.locator("#target-label")).to_contain_text("none")
            expect(page.locator("#photo-gallery .gallery-item")).to_have_count(1)
            expect(page.locator("#photo-gallery")).to_contain_text("Scene image @ 10")
            page.locator("#photo-gallery .gallery-item").first.click()
            if "hidden" in (page.locator("#photo-lightbox").get_attribute("class") or ""):
                raise AssertionError("older scene image did not open in the lightbox")
            expect(page.locator("#photo-lightbox-title")).to_contain_text("Scene image")
            page.locator("#btn-lightbox-close").click()
            expect(page.locator("#portrait-frame img")).to_have_count(1)
            expect(page.locator("#character-name")).to_contain_text("Ash")
            expect(page.locator("#character-info")).to_contain_text("Leporid")
            expect(page.locator("#character-stats")).to_contain_text("HP")
            expect(page.locator("#character-stats")).to_contain_text("8 / 10")
            expect(page.locator("#character-stats")).to_contain_text("AP")
            expect(page.locator("#character-stats")).to_contain_text("FP")
            expect(page.locator("#character-pills")).to_contain_text("ready")
            expect(page.locator("#members")).to_contain_text("Silver Clover")
            expect(page.locator("#inventory")).to_contain_text("Crinkled Map")
            stable_rows = page.evaluate(
                """async () => {
                  const member = document.querySelector('[data-target-id="item:clover"]');
                  const action = document.querySelector('[data-action="wait"]');
                  await window.__world3dPlayer.refresh();
                  return {
                    member: member === document.querySelector('[data-target-id="item:clover"]'),
                    action: action === document.querySelector('[data-action="wait"]'),
                  };
                }"""
            )
            if stable_rows != {"member": True, "action": True}:
                raise AssertionError(f"Preact replaced unchanged keyed HUD rows: {stable_rows!r}")
            page.locator('[data-target-id="item:map"]').click()
            expect(page.locator("#target-label")).to_contain_text("Crinkled Map")
            page.locator('[data-target-id="item:clover"]').click()
            expect(page.locator("#target-label")).to_contain_text("Silver Clover")
            page.locator("#action-filter").fill("inspect")
            page.locator('[data-action="inspect"]').click()
            if page.locator('[data-field="0"]').input_value() != "item:clover":
                raise AssertionError("selected room entity was not preselected in action form")
            page.locator("[data-form-submit]").click()
            if not any(command.get("command_type") == "inspect" and command.get("payload", {}).get("target_id") == "item:clover" for command in COMMAND_PAYLOADS):
                raise AssertionError(f"inspect action did not submit selected target: {COMMAND_PAYLOADS!r}")
            page.locator("#btn-clear-target").click()
            expect(page.locator("#target-label")).to_contain_text("none")
            page.locator("#show-action-icons").uncheck()
            page.reload(wait_until="networkidle")
            page.wait_for_function("window.__world3dPlayer && window.__world3dPlayer.ready")
            if page.locator("#show-action-icons").is_checked():
                raise AssertionError("action icon preference did not persist after reload")
            page.locator("#character-select").select_option("character:ash")
            expect(page.locator("#room-title")).to_contain_text("Sunlit Meadow")
            page.locator("#action-filter").fill("wait")
            expect(page.locator("#actions")).not_to_contain_text("Move")
            page.locator("#action-filter-clear").click()
            expect(page.locator("#actions")).to_contain_text("Move")
            expect(page.locator("#queue")).to_contain_text("Wait")
            page.locator('[data-command-id="cmd-1"]').click()
            expect(page.locator("#queue")).to_contain_text("No queued actions")
            player_before = page.evaluate("window.__world3dPlayer.cameraState()")
            page.locator("#viewer canvas").click(position={"x": 100, "y": 100})
            avatar_before = page.evaluate("window.__world3dPlayer.avatarState()")
            page.keyboard.down("KeyA")
            page.wait_for_timeout(700)
            page.keyboard.up("KeyA")
            avatar_bounded = page.evaluate("window.__world3dPlayer.avatarState()")
            if avatar_bounded["x"] > 15.65:
                raise AssertionError(f"local avatar escaped room bounds: {avatar_bounded!r}")
            page.keyboard.down("KeyW")
            page.wait_for_timeout(180)
            page.keyboard.up("KeyW")
            avatar_after = page.evaluate("window.__world3dPlayer.avatarState()")
            if avatar_after == avatar_before:
                raise AssertionError(f"WASD did not move the local avatar: {avatar_before!r}")
            requests_before_poll = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            page.wait_for_function(
                """async before => (await fetch('./mock/test-claim')).json().then(state =>
                  state.projection_requests > before.projection_requests &&
                  state.room_requests > before.room_requests &&
                  state.event_requests > before.event_requests)""",
                arg=requests_before_poll,
            )
            requests_before_refresh = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            page.locator("#btn-refresh").click()
            page.evaluate("window.__world3dPlayer.refresh()")
            requests_after_refresh = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            for request_key in ("projection_requests", "room_requests", "event_requests"):
                if requests_after_refresh[request_key] != requests_before_refresh[request_key] + 1:
                    raise AssertionError(
                        f"one player refresh duplicated {request_key}: "
                        f"{requests_before_refresh!r} -> {requests_after_refresh!r}"
                    )
            if requests_after_refresh["character_requests"] != requests_before_refresh["character_requests"]:
                raise AssertionError(
                    "a player refresh fetched the character lobby: "
                    f"{requests_before_refresh!r} -> {requests_after_refresh!r}"
                )
            avatar_refreshed = page.evaluate("window.__world3dPlayer.avatarState()")
            if avatar_refreshed != avatar_after:
                raise AssertionError(
                    f"same-room refresh reset local movement: {avatar_after!r} -> {avatar_refreshed!r}"
                )
            player_visual_before_travel = page.evaluate(
                "window.__world3dPlayer.reconciliationState().entities['character:ash']"
            )
            expect(page.locator("#exit-prompt")).not_to_have_class("hidden")
            page.locator("#btn-exit-prompt").click()
            expect(page.locator("#room-title")).to_contain_text("Mirror Pond")
            if not any(command.get("command_type") == "move" and command.get("payload", {}).get("exit_id") == "room:pond" for command in COMMAND_PAYLOADS):
                raise AssertionError(f"exit click did not submit move command: {COMMAND_PAYLOADS!r}")
            page.wait_for_function("!window.__world3dPlayer.cameraState().moving")
            player_after = page.evaluate("window.__world3dPlayer.cameraState()")
            if player_after["target"] == player_before["target"]:
                raise AssertionError(f"player camera did not follow room move: {player_before!r} -> {player_after!r}")
            player_visual_after_travel = page.evaluate(
                "window.__world3dPlayer.reconciliationState().entities['character:ash']"
            )
            if player_visual_after_travel["root"] != player_visual_before_travel["root"] or player_visual_after_travel["model"] != player_visual_before_travel["model"]:
                raise AssertionError("room travel replaced the continuously visible player visual")
            page.locator("#btn-request-image").click()
            expect(page.locator("#activity")).to_contain_text("image")
            expect(page.locator("#photo-gallery .gallery-item")).to_have_count(2)
            page.locator("#btn-open-sheet").click()
            expect(page.locator("#activity")).to_contain_text("Character profile")
            player_canvas = ARTIFACT_DIR / "world-3d-player-canvas.png"
            page.locator("#btn-capture").click()
            if "hidden" in (page.locator("#photo-lightbox").get_attribute("class") or ""):
                raise AssertionError("canvas capture did not open in the lightbox")
            expect(page.locator("#photo-lightbox-title")).to_contain_text("Canvas capture")
            download_lightbox_photo(page, player_canvas)
            if not png_has_detail(player_canvas):
                raise AssertionError("3D player canvas rendered blank pixels")
            page.locator("#btn-lightbox-close").click()
            expect(page.locator("#photo-gallery .gallery-item")).to_have_count(3)
            page.screenshot(
                path=ARTIFACT_DIR / "world-3d-player.png",
                full_page=FULL_PAGE_SCREENSHOTS,
            )

            page.evaluate(
                """async () => fetch('./mock/test-claim', {
                  method: 'POST',
                  headers: {'content-type': 'application/json'},
                  body: JSON.stringify({expired: true, methods: []}),
                })"""
            )
            page.evaluate("window.__world3dPlayer.refresh()")
            expect(page.locator("#status")).to_contain_text("Claim expired")
            expect(page.locator("#btn-claim")).to_have_text("Claim")
            if page.locator("#character-select").input_value() != "character:ash":
                raise AssertionError("claim expiry cleared the selected character")
            stored_claim = page.evaluate(
                "localStorage.getItem('bunnyland.3d.claim.character:ash')"
            )
            if stored_claim is not None:
                raise AssertionError("claim expiry left stale claim credentials in storage")
            expired_state = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            page.wait_for_timeout(2500)
            settled_state = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            if settled_state["projection_requests"] != expired_state["projection_requests"]:
                raise AssertionError(
                    "claim expiry did not stop projection polling: "
                    f"{expired_state!r} -> {settled_state!r}"
                )
            page.locator("#btn-claim").click()
            page.locator("#btn-dialog-claim").click()
            expect(page.locator("#room-title")).to_contain_text("Mirror Pond")
            reclaimed_state = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            if reclaimed_state["methods"][-1:] != ["POST"]:
                raise AssertionError(
                    f"expired claim was not replaced with a fresh POST: {reclaimed_state!r}"
                )

            page.locator("#btn-claim").click()
            page.locator("#btn-dialog-save-fallback").click()
            if not FALLBACK_SAVED:
                raise AssertionError("claim dialog did not save fallback")
            page.locator("#btn-dialog-idle").click()
            if not CONTROLLER_RELEASED:
                raise AssertionError("claim dialog did not idle controller")
            page.locator("#btn-claim").click()
            page.locator("#btn-dialog-claim").click()
            expect(page.locator("#status")).to_contain_text("Reconnecting · polling")
            page.locator("#btn-claim").click()
            page.locator("#btn-dialog-release").click()
            if not CLAIM_RELEASED:
                raise AssertionError("claim dialog did not release claim")

            page.evaluate(
                """async () => {
                  localStorage.setItem('bunnyland.3d.claim.character:ash', JSON.stringify({
                    controllerId: 'controller:web', generation: 3,
                    claimId: 'claim-expired', claimSecret: 'expired-secret',
                    clientId: '3d-test', active: true,
                  }));
                  await fetch('./mock/test-claim', {
                    method: 'POST',
                    headers: {'content-type': 'application/json'},
                    body: JSON.stringify({expired: true, methods: []}),
                  });
                }"""
            )
            page.reload(wait_until="networkidle")
            page.wait_for_function("window.__world3dPlayer && window.__world3dPlayer.ready")
            page.locator("#character-select").select_option("character:ash")
            expect(page.locator("#room-title")).to_contain_text("Mirror Pond")
            resumed_state = page.evaluate(
                """async () => (await fetch('./mock/test-claim')).json()"""
            )
            if resumed_state["methods"][:2] != ["PUT", "POST"]:
                raise AssertionError(
                    f"stale persisted claim did not retry with a fresh POST: {resumed_state!r}"
                )

            page.unroute("**/mock/play/extensions/bunnyland.3d/3d/v2/capabilities")
            page.route(
                "**/mock/play/3d/v2/capabilities",
                lambda route: route.fulfill(status=404, json={"detail": "plugin missing"}),
            )
            page.goto(f"{base_url}/player.html?server={base_url}/mock", wait_until="networkidle")
            expect(page.locator("#status")).to_contain_text("connect failed")
            expect(page.locator("#empty-state-title")).to_contain_text("Connect to a server")
            expect(page.locator("#character-select option")).to_have_count(1)
            browser.close()
    finally:
        if proc is not None:
            proc.terminate()


if __name__ == "__main__":
    main()
