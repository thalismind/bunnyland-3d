def player_3d_scene(room_id: str):
    room = ROOMS.get(room_id, ROOMS["room:meadow"])["room"]
    biome = "meadow" if room_id == "room:meadow" else "marsh"
    exits = [
        {"id": "room:pond", "direction": "east", "label": "Mirror Pond", "locked": False},
        {"id": "room:north", "direction": "north", "label": "North Gate", "locked": True},
    ]
    if room_id == "room:pond":
        exits = [{"id": "room:meadow", "direction": "west", "label": "Sunlit Meadow", "locked": False}]
    entities = []
    for item in room["entities"]:
        transform = item.get("transform3d", {"position": {"x": 8, "y": 0.3, "z": 8}})
        collider = {"shape": "box", "size": {"x": 0.6, "y": 0.6, "z": 0.6}, "solid": True, "static": True}
        if room_id == "room:meadow" and item["id"] == "item:clover":
            transform = {"position": {"x": 14.5, "y": 0.3, "z": 8}}
            collider["solid"] = False
        view = {
            "id": item["id"],
            "name": item["name"],
            "kind": item["kind"],
            "is_character": bool(item.get("is_character")),
            "transform3d": transform,
            "render3d": item.get("render3d", {"shape": "box", "color": "#a6e3a1", "asset_key": "prop.generic"}),
            "collider3d": collider,
        }
        if item["id"] == "item:crate":
            view["transform3d"]["position"]["x"] = SCENE_STATE["crate_x"]
            view["render3d"]["color"] = "#112233"
            view["visual3d"] = {
                "base_model_key": SCENE_STATE["model_asset"],
