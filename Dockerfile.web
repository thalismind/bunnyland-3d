# syntax=docker/dockerfile:1.7

ARG BUNNYLAND_WEB_IMAGE=ghcr.io/thalismind/bunnyland-web:main

FROM node:22-bookworm-slim AS build

WORKDIR /app/web

COPY --from=bunnyland-ui-web / /bunnyland-ui-web
COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/index.html web/admin.html web/player.html web/vite.config.ts web/tsconfig.json ./
COPY web/src ./src

ENV BUNNYLAND_3D_BASE=/3d/
RUN npm run build

FROM build AS test

COPY web/test ./test
RUN npm test

FROM mcr.microsoft.com/playwright/python:v1.56.0-noble AS browser-test

WORKDIR /app/web
COPY --from=build /app/web/dist ./dist
COPY web/scripts ./scripts
RUN BUNNYLAND_3D_ARTIFACT_DIR=/tmp/bunnyland-3d-artifacts ./scripts/playwright-world-3d

FROM ${BUNNYLAND_WEB_IMAGE} AS runtime

COPY --from=build /app/web/dist /usr/share/nginx/html/3d
